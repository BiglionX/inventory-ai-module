{
  "builds": [
    {
      "src": "docs/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "docs/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/$",
      "dest": "/docs/inventory-ai-module.html"
    },
    {
      "src": "/(.*)",
      "dest": "/docs/"
    }
  ]
}
